<view class="container">
  <view class="welcome">
    <text class="icon">🔗</text>
    <text class="title">输入邀请码加入店铺</text>
    <text class="desc">向店铺创建者获取6位邀请码</text>
  </view>

  <view class="code-inputs" bindtap="focusInput">
    <view class="code-input {{code[0] ? 'filled' : ''}} {{focusIndex === 0 && code[0] === '' ? 'active' : ''}}">{{code[0]}}</view>
    <view class="code-input {{code[1] ? 'filled' : ''}} {{focusIndex === 1 && code[1] === '' ? 'active' : ''}}">{{code[1]}}</view>
    <view class="code-input {{code[2] ? 'filled' : ''}} {{focusIndex === 2 && code[2] === '' ? 'active' : ''}}">{{code[2]}}</view>
    <view class="code-input {{code[3] ? 'filled' : ''}} {{focusIndex === 3 && code[3] === '' ? 'active' : ''}}">{{code[3]}}</view>
    <view class="code-input {{code[4] ? 'filled' : ''}} {{focusIndex === 4 && code[4] === '' ? 'active' : ''}}">{{code[4]}}</view>
    <view class="code-input {{code[5] ? 'filled' : ''}} {{focusIndex === 5 && code[5] === '' ? 'active' : ''}}">{{code[5]}}</view>
    <input class="hidden-input" type="number" maxlength="6" value="{{inputValue}}" bindinput="onInput" focus="{{inputFocus}}" />
  </view>

  <button class="btn-primary" bindtap="joinShop" disabled="{{inputValue.length < 6}}">加入店铺</button>
</view>
