.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40px 24px;
}

.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40px;
}

.icon {
  font-size: 56px;
  margin-bottom: 20px;
}

.title {
  font-size: 24px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
}

.desc {
  font-size: 14px;
  color: #999;
}

.actions {
  width: 100%;
}

.btn-outline {
  width: 100%;
  background: #fff;
  color: #07C160;
  border: 2px solid #07C160;
  border-radius: 10px;
  padding: 14px;
  font-size: 16px;
  font-weight: bold;
  margin-top: 12px;
}

.btn-outline::after {
  border: none;
}
