<view class="container">
  <view class="welcome">
    <text class="icon">🐟</text>
    <text class="desc">轻松管理你的销售收入</text>
  </view>

  <view class="profile-card" wx:if="{{needProfile}}">
    <view class="avatar-wrapper">
     <button 
     class="avatar-btn" 
     open-type="chooseAvatar" 
     bindchooseavatar="onChooseAvatar"
     >
    <!-- 有头像时显示图片 -->
      <image 
        wx:if="{{avatarUrl}}" 
        class="avatar-img" 
        src="{{avatarUrl}}" 
        mode="aspectFill"
      />
      <!-- 无头像时显示占位文字 -->
      <view wx:else class="avatar-placeholder">点击头像</view>
    </button>
  </view>
    <input class="nickname-input" type="nickname" placeholder="点击获取昵称" value="{{nickName}}" bindinput="onInputNickName" />
  </view>

  <view class="actions" wx:if="{{!needProfile || profileReady}}">
    <button class="btn-primary" bindtap="goCreate">创建我的店铺</button>
    <button class="btn-outline" bindtap="goJoin">加入已有店铺</button>
  </view>
</view>
